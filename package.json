{
  "name": "m-prompt",
  "version": "1.0.1",
  "description": "M-Prompt - AI 提示词引擎 | 365 专业提示词一键组合",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "web": "python3 -m http.server 4173 -d web",
    "server": "node server/server.js",
    "serve": "node server/server.js",
    "codes": "node scripts/generate-codes.js",
    "build:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "author": "M-Prompt Studio",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.mprompt.app",
    "productName": "M-Prompt",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "assets/icon.icns",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 190
        },
        {
          "x": 400,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/*.enc",
      "src/decrypt.js",
      "src/app.js",
      "src/*.html",
      "src/*.css",
      "assets/**/*"
    ]
  },
  "dependencies": {
    "bytenode": "^1.5.7"
  }
}
